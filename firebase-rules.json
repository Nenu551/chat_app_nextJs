{
  "rules": {
    "rooms": {
      "$roomId": {
        "messages": {
          ".read": "true",
          ".write": "true",
          "$messageId": {
            ".validate": "newData.hasChildren(['sender', 'text', 'timestamp'])",
            "sender": {
              ".validate": "newData.isString() && newData.val().length > 0"
            },
            "text": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 2000"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
